{
  "name": "Aphelion",
  "maker": "Penumbra",
  "motif": "corona eclipse + aphelion orbit",
  "color": {
    "brand": {
      "corona":  { "value": "#5EEAD4", "role": "Primary glow — mint-teal. Rings, links, primary accents." },
      "flare":   { "value": "#22D3EE", "role": "Secondary glow — cyan. Gradients, hover, emphasis." },
      "magenta": { "value": "#FF79C6", "role": "Accent — the aphelion planet. Use sparingly, ~5% of a layout." },
      "violet":  { "value": "#C084FC", "role": "Accent — secondary pop / planet core. Badges, highlights." }
    },
    "void": {
      "900": { "value": "#07021A", "role": "Deepest base background." },
      "800": { "value": "#0C0426", "role": "Surface / cards." },
      "700": { "value": "#130A30", "role": "Raised panels / inputs." }
    },
    "text": {
      "primary": { "value": "#ECFEFF", "role": "Primary text on void." },
      "dim":     { "value": "#9DB4BC", "role": "Secondary / muted text." },
      "faint":   { "value": "#5A6B78", "role": "Labels, captions, disabled." }
    },
    "functional": {
      "border": { "value": "rgba(94,234,212,0.16)", "role": "Hairline borders / dividers." },
      "glow":   { "value": "0 0 48px rgba(34,211,238,0.35)", "role": "Standard glow shadow." }
    }
  },
  "gradient": {
    "corona": "radial-gradient(circle, #5EEAD4 0%, #22D3EE 70%, rgba(34,211,238,0) 100%)",
    "void":   "radial-gradient(120% 100% at 50% 0%, #130A30 0%, #0C0426 55%, #07021A 100%)"
  },
  "font": {
    "heading": { "family": "Space Grotesk", "fallback": "Segoe UI, system-ui, sans-serif", "weights": [400, 500, 700] },
    "mono":    { "family": "JetBrains Mono", "fallback": "Consolas, monospace", "weights": [400, 500, 700] }
  },
  "typeScale": {
    "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.25rem",
    "xl": "1.563rem", "2xl": "1.953rem", "3xl": "2.441rem", "4xl": "3.815rem", "5xl": "5.96rem"
  },
  "type": {
    "leadingTight": 1.05,
    "leadingBody": 1.6,
    "trackingTight": "-0.02em",
    "trackingMono": "0.04em"
  },
  "radius": { "sm": "8px", "md": "14px", "lg": "22px", "icon": "22%" }
}
