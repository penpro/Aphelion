{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aphelion",
  "mainBinaryName": "Aphelion",
  "version": "0.1.24",
  "identifier": "com.localllm.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Aphelion",
        "decorations": false,
        "width": 1400,
        "height": 900,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:11435 http://localhost:11435"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb"],
    "resources": {
      "bin/llama/": "llama/",
      "bin/typst/": "typst/"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/penpro/Aphelion/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBQUU4RUQ3RDQzRTQ3QzQKUldURVJ6N1UxNDZ1NmhheVMvUzZSczVLaFU3TTRUSzAzNWE3Zjg4MUJhVGZJbFpKZ045WTU4angK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
